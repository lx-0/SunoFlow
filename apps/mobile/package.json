{
  "name": "sunoflow-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "release": "expo run:ios --configuration Release --device",
    "release:check": "tsc --noEmit && expo lint && expo run:ios --configuration Release --device",
    "prebuild": "expo prebuild -p ios --clean",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint"
  },
  "dependencies": {
    "@simform_solutions/react-native-audio-waveform": "^2.1.6",
    "@sunoflow/core": "link:../../packages/core",
    "expo": "~56.0.8",
    "expo-audio": "~56.0.11",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-modules-core": "~56.0.14",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-video": "~56.1.2",
    "lucide-react-native": "^1.17.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "typescript": "~5.9.2"
  },
  "comment": "Versions pinned to Expo SDK 56 (from expo/bundledNativeModules.json sdk-56) so a plain `pnpm install` gets the right tree without `expo install --fix`. Audio = expo-audio (free, New-Arch). reanimated 4 needs react-native-worklets (0.8.3). UNTESTED scaffold."
}
