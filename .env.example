# =============================================================================
# SunoFlow — Environment Variable Reference
# Copy this file to .env and fill in the values before running the app.
# =============================================================================

# --- Database (required) ---
# Used by the Next.js app (env.ts validation)
DATABASE_URL="postgres://projects:projects@localhost:5433/sunoflow"
# Used by Prisma schema (prisma migrate deploy / prisma generate)
SUNOFLOW_DATABASE_URL="postgres://projects:projects@localhost:5433/sunoflow"

# --- Auth (required) ---
# Generate a secret with: npx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
# NEXTAUTH_URL="http://localhost:3000"  # Alternative NextAuth URL override

# --- Suno API (optional) ---
# API key from sunoapi.org — required for music generation.
# Users can also set their own key in Settings > API Key.
# If omitted, the app falls back to mock/demo data.
SUNOAPI_KEY=""
# Timeout for Suno API calls in milliseconds (default: 30000)
# SUNO_API_TIMEOUT_MS=30000

# --- OpenAI (optional) ---
# Required for LLM text generation (lyrics, prompts, etc.)
OPENAI_API_KEY=""
# Override default model (default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o-mini"

# --- Email / Mailjet (optional) ---
# Falls back to console.log when these are not set
# MAILJET_API_KEY=""
# MAILJET_SECRET_KEY=""
# EMAIL_FROM="noreply@sunoflow.com"

# --- Instagram oEmbed (optional) ---
# Required for the Inspire page Instagram mood board feature.
# Instagram's oEmbed endpoint requires app-level credentials since 2025.
# Setup: create a Meta App → add Instagram Graph API → get credentials from
# Meta App Dashboard → Settings → Advanced → Client Token.
# Your app must have the "oembed_read" permission.
# INSTAGRAM_APP_ID=""
# INSTAGRAM_CLIENT_TOKEN=""

# --- Google OAuth (optional) ---
# Sign-in button is hidden when these are empty
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Site URL (optional) ---
# Public-facing base URL used for Open Graph tags, sitemaps, and share links
# NEXT_PUBLIC_SITE_URL="https://sunoflow.app"

# --- CORS (optional) ---
# Comma-separated list of allowed origins for cross-origin requests.
# Leave unset for same-origin only (recommended for production).
# ALLOWED_ORIGINS="https://app.example.com,https://staging.example.com"

# --- Rate limiting (optional) ---
# Max AI generation requests per user per time window (default: 10)
# RATE_LIMIT_MAX_GENERATIONS=10

# --- Logging (optional) ---
# Log level: trace | debug | info | warn | error | fatal (default: info in prod, debug in dev)
# LOG_LEVEL="info"
# Pretty-print logs in development (default: false; JSON logs always used in production)
# LOG_PRETTY="true"

# --- Stripe (optional) ---
# Required for subscription billing.
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Webhook signing secret from: https://dashboard.stripe.com/webhooks
# STRIPE_WEBHOOK_SECRET=""
# Price IDs for each subscription tier (from Stripe Dashboard > Products)
# STRIPE_PRICE_STARTER=""
# STRIPE_PRICE_PRO=""
# STRIPE_PRICE_STUDIO=""
# Credit top-up price IDs (from Stripe Dashboard > Products)
# STRIPE_PRICE_TOPUP_10=""
# STRIPE_PRICE_TOPUP_25=""
# STRIPE_PRICE_TOPUP_50=""

# --- Web Push / VAPID (optional) ---
# Generate keys with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
# Without these, push notifications are disabled (app still works normally).
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:noreply@sunoflow.app"

# --- Analytics / PostHog (optional) ---
# Leave unset to disable analytics tracking
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- In-app feedback webhook (optional) ---
# If set, the feedback widget will fire-and-forget POST feedback payloads to this URL.
# Payload: { source, entityId, rating, comment? }
# NEXT_PUBLIC_FEEDBACK_WEBHOOK_URL=""

# --- Audio cache (recommended in production) ---
# Directory for locally cached audio files. Once downloaded from Suno, audio
# is served from this cache so playback never depends on Suno URL availability.
# In production (e.g. Railway), point this to a persistent volume so files
# survive redeployments. Without this, cached files are lost on every deploy
# and expired Suno URLs will cause "Audio unavailable" errors.
AUDIO_CACHE_DIR="/data/audio-cache"
# Max songs to pre-cache on server startup (default: 100, ordered by play count)
# CACHE_WARMUP_BATCH_SIZE=100

# --- Cron Jobs (optional) ---
# Bearer token that Railway/cron callers must send to authenticate scheduled jobs.
# Generate with: openssl rand -hex 32
# CRON_SECRET=""

# --- Sentry (optional) ---
# Leave unset to disable Sentry error tracking
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# Override environment tag sent to Sentry (defaults to NODE_ENV).
# Set to "production" in Railway prod, "staging" in staging, etc.
# SENTRY_ENVIRONMENT="production"
# NEXT_PUBLIC_SENTRY_ENVIRONMENT="production"
# Release tag for source map association. Automatically set from
# RAILWAY_GIT_COMMIT_SHA in Railway; set manually otherwise.
# SENTRY_RELEASE=""
# NEXT_PUBLIC_SENTRY_RELEASE=""
# Only needed if you want source maps uploaded to Sentry during build
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
