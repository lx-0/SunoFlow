generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("SUNOFLOW_DATABASE_URL")
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash         String?
  sunoApiKey           String?
  usePersonalApiKey    Boolean   @default(false)
  verificationToken    String?   @unique
  resetToken           String?   @unique
  resetTokenExpiry     DateTime?
  isAdmin              Boolean   @default(false)
  isDisabled           Boolean   @default(false)
  username             String?   @unique
  bio                  String?
  avatarUrl            String?
  bannerUrl            String?
  featuredSongId       String?
  defaultStyle         String?
  preferredGenres      String[]  @default([])
  onboardingCompleted      Boolean   @default(false)
  emailWelcome             Boolean   @default(true)
  emailGenerationComplete  Boolean   @default(false)
  emailDigestFrequency     String    @default("off")
  quietHoursEnabled        Boolean   @default(false)
  quietHoursStart          Int       @default(22)
  quietHoursEnd            Int       @default(8)
  unsubscribeToken         String?   @unique
  pushGenerationComplete   Boolean   @default(true)
  pushNewFollower          Boolean   @default(true)
  pushSongComment          Boolean   @default(true)
  lastLoginAt              DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  songs            Song[]
  playlists        Playlist[]
  rateLimitEntries RateLimitEntry[]
  promptTemplates  PromptTemplate[]
  userTags         Tag[]
  favorites        Favorite[]
  adminLogs        AdminLog[] @relation("adminLogs")
  reports          Report[]
  appeals          Appeal[]
  notifications    Notification[]
  rssFeeds              RssFeedSubscription[]
  pendingFeedGenerations PendingFeedGeneration[]
  personas              Persona[]
  apiKeys          ApiKey[]
  ratings          Rating[]
  creditUsages     CreditUsage[]
  generationQueue  GenerationQueueItem[]
  comments         Comment[]
  followers        Follow[]  @relation("Following")
  following        Follow[]  @relation("Follower")
  activities       Activity[]
  reactions            SongReaction[]
  generationFeedbacks  GenerationFeedback[]
  generationPresets    GenerationPreset[]
  userFeedbacks        UserFeedback[]
  subscription         Subscription?
  paymentEvents        PaymentEvent[]
  creditTopUps         CreditTopUp[]
  playHistory          PlayHistory[]
  playlistCollaborations PlaylistCollaborator[]
  playlistSongsAdded     PlaylistSong[]         @relation("PlaylistSongAddedBy")
  playbackState        PlaybackState?
  generationAttempts   GenerationAttempt[]
  inspirationDigests   InspirationDigest[]
  streak               UserStreak?
  milestones           UserMilestone[]
  pushSubscriptions    PushSubscription[]
  styleTemplates       StyleTemplate[]

  @@index([lastLoginAt])
  @@index([createdAt])
  @@index([isAdmin])
  @@index([isDisabled])
}

model Activity {
  id         String   @id @default(cuid())
  userId     String
  type       String   // "song_created", "playlist_created", "song_favorited"
  songId     String?
  playlistId String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  song     Song?     @relation(fields: [songId], references: [id], onDelete: Cascade)
  playlist Playlist? @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([type, createdAt])
}

model Song {
  id               String   @id @default(cuid())
  userId           String
  sunoJobId        String?  @unique
  sunoAudioId      String?
  title            String?
  prompt           String?
  tags             String?
  audioUrl             String?
  audioUrlExpiresAt    DateTime?
  imageUrl             String?
  imageUrlExpiresAt    DateTime?
  imageUrlIsCustom     Boolean  @default(false)
  videoUrl             String?
  duration         Float?
  lyrics           String?
  lyricsEdited     String?  @db.Text
  sunoModel        String?
  isInstrumental   Boolean  @default(false)
  generationStatus String   @default("pending")
  errorMessage     String?
  pollCount        Int      @default(0)
  tempo            Int?
  isFavorite       Boolean  @default(false)
  isPublic         Boolean  @default(false)
  isHidden         Boolean  @default(false)
  publicSlug       String?  @unique
  rating           Int?
  ratingNote       String?
  downloadCount    Int      @default(0)
  playCount        Int      @default(0)
  viewCount        Int      @default(0)
  parentSongId         String?
  batchId              String?
  source               String?  @default("manual") // "manual" | "auto"
  rssFeedSubscriptionId String?
  archivedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentSong    Song?          @relation("SongVariations", fields: [parentSongId], references: [id], onDelete: SetNull)
  rssFeedSubscription RssFeedSubscription? @relation(fields: [rssFeedSubscriptionId], references: [id], onDelete: SetNull)
  variations    Song[]         @relation("SongVariations")
  playlistSongs PlaylistSong[]
  songTags      SongTag[]
  favorites     Favorite[]
  reports       Report[]
  appeals       Appeal[]
  ratings       Rating[]
  queueItems    GenerationQueueItem[]
  comments      Comment[]
  reactions            SongReaction[]
  generationFeedbacks  GenerationFeedback[]
  playHistory          PlayHistory[]
  activities           Activity[]
  lyricTimestamps      LyricTimestamp[]
  lyricAnnotations     LyricAnnotation[]
  playbackStates       PlaybackState[]
  playEvents           PlayEvent[]
  viewEvents           SongView[]
  generationAttempt    GenerationAttempt?
  songEmbedding        SongEmbedding?
  collectionSongs      CollectionSong[]
  styleTemplates       StyleTemplate[]

  @@index([userId, title])
  @@index([userId, prompt])
  @@index([userId, createdAt])
  @@index([userId, playCount])
  @@index([parentSongId])
  @@index([userId, archivedAt])
  @@index([generationStatus])
  @@index([userId, generationStatus])
  @@index([userId, rating])
  @@index([userId, updatedAt])
  @@index([userId, tempo])
  @@index([isPublic, generationStatus, isHidden])
  @@index([isPublic, createdAt])
  @@index([isPublic, playCount])
  @@index([isPublic, rating])
  @@index([userId, source])
  @@index([rssFeedSubscriptionId, source, createdAt])
  @@index([generationStatus, createdAt])
  @@index([userId, isFavorite])
  @@index([userId, downloadCount])
  @@index([batchId])
}

model Playlist {
  id               String   @id @default(cuid())
  name             String
  description      String?
  userId           String
  isPublic         Boolean  @default(false)
  isCollaborative  Boolean  @default(false)
  slug             String?  @unique
  shareCount       Int      @default(0)
  isPublished      Boolean  @default(false)
  publishedAt      DateTime?
  genre            String?
  playCount        Int      @default(0)
  isSmartPlaylist  Boolean  @default(false)
  smartPlaylistType String? // "top_hits" | "new_this_week" | "mood" | "similar_to"
  smartPlaylistMeta Json?   // e.g. {"mood": "chill"} or {"sourceSongId": "..."}
  smartRefreshedAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  songs         PlaylistSong[]
  activities    Activity[]
  collaborators PlaylistCollaborator[]
  reports       Report[]               @relation("PlaylistReports")

  @@index([userId])
  @@index([userId, name])
  @@index([userId, isSmartPlaylist])
  @@index([isPublished, publishedAt])
}

model PlaylistSong {
  id            String   @id @default(cuid())
  playlistId    String
  songId        String
  position      Int
  addedAt       DateTime @default(now())
  addedByUserId String?

  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song        Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  addedByUser User?    @relation("PlaylistSongAddedBy", fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@unique([playlistId, songId])
  @@index([playlistId, position])
}

model PlaylistCollaborator {
  id               String    @id @default(cuid())
  playlistId       String
  userId           String?   // null until invite is accepted
  inviteToken      String    @unique @default(cuid())
  inviteExpiresAt  DateTime
  status           String    @default("pending") // pending, accepted
  role             String    @default("editor")  // editor, viewer
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([playlistId])
  @@index([userId])
  @@index([inviteToken])
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  userId    String
  action    String   @default("generate")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, createdAt])
}

model PromptTemplate {
  id             String   @id @default(cuid())
  userId         String?
  name           String
  description    String?
  prompt         String
  style          String?
  category       String?
  isInstrumental Boolean  @default(false)
  isBuiltIn      Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#7c3aed")
  userId    String
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  songTags SongTag[]

  @@unique([userId, name])
  @@index([userId])
}

model SongTag {
  id        String   @id @default(cuid())
  songId    String
  tagId     String
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([songId, tagId])
  @@index([songId])
  @@index([tagId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  songId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([userId, songId])
  @@index([userId])
  @@index([songId])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())

  admin User @relation("adminLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
}

model Report {
  id          String   @id @default(cuid())
  songId      String?
  playlistId  String?
  reporterId  String
  reason      String   // offensive, copyright, spam, other
  description String?
  status      String   @default("pending") // pending, reviewed, actioned, dismissed
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  song     Song?     @relation(fields: [songId], references: [id], onDelete: Cascade)
  playlist Playlist? @relation("PlaylistReports", fields: [playlistId], references: [id], onDelete: Cascade)
  reporter User      @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([songId, reporterId])
  @@unique([playlistId, reporterId])
  @@index([songId])
  @@index([playlistId])
  @@index([reporterId])
  @@index([status, createdAt])
}

model Appeal {
  id         String    @id @default(cuid())
  songId     String
  userId     String
  reason     String    @db.Text
  status     String    @default("pending") // pending, approved, rejected
  adminNote  String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
  @@index([status, createdAt])
  @@index([userId])
  @@index([songId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // generation_complete, generation_failed, rate_limit_reset, announcement
  title     String
  message   String
  href      String?
  songId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RssFeedSubscription {
  id             String    @id @default(cuid())
  userId         String
  url            String
  title          String?
  autoGenerate   Boolean   @default(false)
  lastCheckedAt  DateTime?
  createdAt      DateTime  @default(now())

  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  pendingGenerations PendingFeedGeneration[]
  autoGeneratedSongs Song[]

  @@unique([userId, url])
  @@index([userId])
  @@index([autoGenerate])
}

model PendingFeedGeneration {
  id                  String    @id @default(cuid())
  userId              String
  feedSubscriptionId  String?
  feedTitle           String?
  itemTitle           String
  itemLink            String?
  itemPubDate         String?
  prompt              String
  style               String?
  status              String    @default("pending") // pending, approved, dismissed
  createdAt           DateTime  @default(now())

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedSubscription RssFeedSubscription? @relation(fields: [feedSubscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([feedSubscriptionId])
}

model Persona {
  id          String   @id @default(cuid())
  userId      String
  personaId   String   // Suno API persona ID
  name        String
  description String?
  style       String?
  sourceSongId String? // Song used to create this persona
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, personaId])
  @@index([userId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  songId    String
  value     Int      // 1-5 stars
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([userId, songId])
  @@index([songId])
  @@index([userId])
}

enum GenerationFeedbackRating {
  thumbs_up
  thumbs_down
}

model GenerationFeedback {
  id        String                   @id @default(cuid())
  songId    String
  userId    String
  rating    GenerationFeedbackRating
  createdAt DateTime                 @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([songId, userId])
  @@index([songId])
  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String
  prefix     String    @db.VarChar(12)
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
}

model CreditUsage {
  id          String   @id @default(cuid())
  userId      String
  action      String   // "generate", "extend", "cover", "lyrics", "style_boost", "mashup"
  creditCost  Int      @default(0)
  songId      String?
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, action])
  @@index([createdAt])
}

model GenerationQueueItem {
  id             String   @id @default(cuid())
  userId         String
  prompt         String
  title          String?
  tags           String?
  makeInstrumental Boolean @default(false)
  personaId      String?
  status         String   @default("pending") // pending, processing, done, failed, cancelled
  position       Int
  songId         String?  // linked Song once generation starts
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song? @relation(fields: [songId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, position])
  @@index([status])
}

model ErrorReport {
  id        String   @id @default(cuid())
  message   String
  stack     String?  @db.Text
  url       String
  userAgent String?
  source    String   // error-boundary, unhandled-error, unhandled-rejection
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([source])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Comment {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  body      String   @db.Text
  timestamp Float?   // seconds into the song; null = non-timestamped comment
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([songId, createdAt])
  @@index([songId, timestamp])
  @@index([userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model SongReaction {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  emoji     String   // single emoji character
  timestamp Float    // seconds into the song
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([songId])
  @@index([userId])
  @@unique([songId, userId, emoji, timestamp])
}

model GenerationPreset {
  id             String   @id @default(cuid())
  userId         String
  name           String
  title          String?
  stylePrompt    String?
  lyricsPrompt   String?
  isInstrumental Boolean  @default(false)
  customMode     Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model UserFeedback {
  id            String   @id @default(cuid())
  userId        String
  category      String   // bug_report, feature_request, general
  score         Int?     // 1-5, optional
  comment       String?  @db.Text
  screenshotUrl String?
  pageUrl       String
  userAgent     String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category, createdAt])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Stripe billing models
// ---------------------------------------------------------------------------

enum SubscriptionTier {
  free
  starter
  pro
  studio
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  unpaid
  incomplete
  incomplete_expired
  paused
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String             @unique
  stripePriceId        String
  tier                 SubscriptionTier   @default(free)
  status               SubscriptionStatus @default(active)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([status])
  @@index([status, tier])
}

model PaymentEvent {
  id               String   @id @default(cuid())
  userId           String?
  stripeEventId    String   @unique
  type             String
  amount           Int?     // in cents
  currency         String?
  status           String
  stripeCustomerId String?
  metadata         Json?
  processedAt      DateTime @default(now())
  createdAt        DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([stripeEventId])
  @@index([type, processedAt])
  @@index([stripeCustomerId])
}

model PlayHistory {
  id       String   @id @default(cuid())
  userId   String
  songId   String
  playedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt(sort: Desc)])
  @@index([songId])
  @@index([userId, songId, playedAt(sort: Desc)])
}

model LyricTimestamp {
  id        String   @id @default(cuid())
  songId    String
  lineIndex Int      // 0-based index into lyric lines
  startTime Float    // seconds from start of audio
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([songId, lineIndex])
  @@index([songId])
}

model PlaybackState {
  id        String   @id @default(cuid())
  userId    String   @unique
  songId    String
  position  Float    @default(0)
  queue     Json     @default("[]")
  volume          Float    @default(1)
  shuffleVersions Boolean  @default(false)
  shuffle         Boolean  @default(false)
  repeat          String   @default("off")
  muted           Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LyricAnnotation {
  id        String   @id @default(cuid())
  songId    String
  lineIndex Int      // 0-based index into lyric lines
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([songId, lineIndex])
  @@index([songId])
}

model PlayEvent {
  id          String   @id @default(cuid())
  songId      String
  listenerId  String?  // null for anonymous
  startedAt   DateTime @default(now())
  durationSec Float?   // seconds listened; null if not recorded

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId, startedAt])
  @@index([listenerId, startedAt])
  @@index([listenerId])
}

model GenerationAttempt {
  id           String   @id @default(cuid())
  userId       String
  prompt       String
  params       Json     // { title, style, instrumental, personaId }
  status       String   @default("pending") // pending / complete / failed
  songId       String?  @unique
  errorMessage String?
  createdAt    DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song? @relation(fields: [songId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
}

// Anonymized public song page view events — no PII, just songId + timestamp
model SongView {
  id        String   @id @default(cuid())
  songId    String
  viewedAt  DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId, viewedAt])
  @@index([viewedAt])
}

model CreditTopUp {
  id                    String    @id @default(cuid())
  userId                String
  credits               Int       // credits purchased
  amountCents           Int       // price paid in cents
  currency              String    @default("usd")
  stripeSessionId       String    @unique
  stripePaymentIntentId String?
  expiresAt             DateTime? // null = no expiry; set to 1 year on creation
  createdAt             DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, expiresAt])
  @@index([stripeSessionId])
}

model InspirationDigest {
  id        String   @id @default(cuid())
  userId    String
  title     String
  items     Json     // DigestItem[]
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// Stores OpenAI embedding vectors for songs to power semantic recommendations.
// One row per song; updated whenever the song's metadata changes significantly.
model SongEmbedding {
  id        String   @id @default(cuid())
  songId    String   @unique
  embedding Json     // float[] — text-embedding-3-small (1536 dims)
  model     String   @default("text-embedding-3-small")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId])
  @@index([updatedAt])
}

// ─── Engagement: Streaks & Milestones ─────────────────────────────────────────

// Tracks a user's daily active streak.
// lastActiveDate is stored as a UTC date string "YYYY-MM-DD".
model UserStreak {
  id             String   @id @default(cuid())
  userId         String   @unique
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActiveDate String?  // "YYYY-MM-DD" UTC; null = never active
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// One row per earned milestone; milestones are never deleted.
model UserMilestone {
  id       String   @id @default(cuid())
  userId   String
  type     String   // see MILESTONE_TYPES in src/lib/streaks.ts
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

// Rate limit entries for anonymous/IP-based limiting (no user FK).
// Used for unauthenticated endpoints like /api/register where no userId exists.
model AnonRateLimitEntry {
  id        String   @id @default(cuid())
  key       String   // hashed IP, email hash, or other anonymous identifier
  action    String
  createdAt DateTime @default(now())

  @@index([key, action, createdAt])
}

// ─── Curated Collections ──────────────────────────────────────────────────────

// Themed groupings of public songs for the Discover page (e.g. "Chill Vibes").
// Auto-generated from song metadata; manual curation deferred to a future release.
model Collection {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverImage  String?  // URL to representative artwork
  theme       String?  // internal tag used to build the collection (e.g. "chill")
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  songs CollectionSong[]

  @@index([isPublic, createdAt(sort: Desc)])
}

// Join table: Collection ↔ Song (ordered by position)
model CollectionSong {
  id           String   @id @default(cuid())
  collectionId String
  songId       String
  position     Int      @default(0)
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  song       Song       @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([collectionId, songId])
  @@index([collectionId, position])
  @@index([songId])
}

model StyleTemplate {
  id           String   @id @default(cuid())
  userId       String
  name         String
  tags         String
  sourceSongId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSong Song? @relation(fields: [sourceSongId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([sourceSongId])
}
