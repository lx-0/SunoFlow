generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("SUNOFLOW_DATABASE_URL")
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash         String?
  sunoApiKey           String?
  verificationToken    String?   @unique
  resetToken           String?   @unique
  resetTokenExpiry     DateTime?
  isAdmin              Boolean   @default(false)
  isDisabled           Boolean   @default(false)
  bio                  String?
  avatarUrl            String?
  defaultStyle         String?
  preferredGenres      String[]  @default([])
  onboardingCompleted  Boolean   @default(false)
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  songs            Song[]
  playlists        Playlist[]
  rateLimitEntries RateLimitEntry[]
  promptTemplates  PromptTemplate[]
  userTags         Tag[]
  favorites        Favorite[]
  adminLogs        AdminLog[] @relation("adminLogs")
  reports          Report[]
  notifications    Notification[]
  rssFeeds         RssFeedSubscription[]
  personas         Persona[]
  apiKeys          ApiKey[]
}

model Song {
  id               String   @id @default(cuid())
  userId           String
  sunoJobId        String?  @unique
  title            String?
  prompt           String?
  tags             String?
  audioUrl         String?
  imageUrl         String?
  duration         Float?
  lyrics           String?
  sunoModel        String?
  isInstrumental   Boolean  @default(false)
  generationStatus String   @default("pending")
  errorMessage     String?
  pollCount        Int      @default(0)
  isFavorite       Boolean  @default(false)
  isPublic         Boolean  @default(false)
  isHidden         Boolean  @default(false)
  publicSlug       String?  @unique
  rating           Int?
  ratingNote       String?
  downloadCount    Int      @default(0)
  playCount        Int      @default(0)
  parentSongId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentSong    Song?          @relation("SongVariations", fields: [parentSongId], references: [id], onDelete: SetNull)
  variations    Song[]         @relation("SongVariations")
  playlistSongs PlaylistSong[]
  songTags      SongTag[]
  favorites     Favorite[]
  reports       Report[]

  @@index([userId, title])
  @@index([userId, prompt])
  @@index([userId, createdAt])
  @@index([userId, playCount])
  @@index([parentSongId])
}

model Playlist {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  songs PlaylistSong[]

  @@index([userId])
  @@index([userId, name])
}

model PlaylistSong {
  id         String   @id @default(cuid())
  playlistId String
  songId     String
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([playlistId, songId])
  @@index([playlistId, position])
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  userId    String
  action    String   @default("generate")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, createdAt])
}

model PromptTemplate {
  id             String   @id @default(cuid())
  userId         String?
  name           String
  description    String?
  prompt         String
  style          String?
  category       String?
  isInstrumental Boolean  @default(false)
  isBuiltIn      Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#7c3aed")
  userId    String
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  songTags SongTag[]

  @@unique([userId, name])
  @@index([userId])
}

model SongTag {
  id        String   @id @default(cuid())
  songId    String
  tagId     String
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([songId, tagId])
  @@index([songId])
  @@index([tagId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  songId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([userId, songId])
  @@index([userId])
  @@index([songId])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())

  admin User @relation("adminLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
}

model Report {
  id          String   @id @default(cuid())
  songId      String
  reporterId  String
  reason      String   // offensive, copyright, spam, other
  description String?
  status      String   @default("pending") // pending, reviewed, actioned, dismissed
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  song     Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([songId])
  @@index([reporterId])
  @@index([status, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // generation_complete, generation_failed, rate_limit_reset, announcement
  title     String
  message   String
  href      String?
  songId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

model RssFeedSubscription {
  id        String   @id @default(cuid())
  userId    String
  url       String
  title     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId])
}

model Persona {
  id          String   @id @default(cuid())
  userId      String
  personaId   String   // Suno API persona ID
  name        String
  description String?
  style       String?
  sourceSongId String? // Song used to create this persona
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, personaId])
  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String
  prefix     String    @db.VarChar(12)
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
